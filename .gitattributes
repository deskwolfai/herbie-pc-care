# Default: text files are normalized to LF in the repo, native on checkout
* text=auto eol=lf

# Explicit text formats
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.svg   text eol=lf

# Binaries (don't touch)
*.jpg   binary
*.jpeg  binary
*.png   binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
