# Copy values into Vercel → Project → Settings → Environment Variables.
# Do NOT commit a real .env file (already excluded by .gitignore).
#
# At least ONE of the two pipelines below must be configured. If both
# are configured (recommended), each submission emails Herbie via Resend
# AND appends a row to your Google Sheet for tracking.

# ─── Pipeline 1 — Resend (email notification) ──────────────────────────

# Resend secret. Create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Where the form submissions land. Defaults to contact@deskwolf.ai if unset.
INTAKE_TO=contact@deskwolf.ai

# Sender address shown in the inbox.
# Default (works immediately, no domain verification):
#   onboarding@resend.dev   — Resend's shared test sender. NB: it can only
#   deliver to the email address you signed up for Resend with.
# Once you verify deskwolf.ai in Resend (Dashboard → Domains), set this to
# something custom, e.g.:
#   INTAKE_FROM=Herbie PC Care <intake@deskwolf.ai>
INTAKE_FROM=Herbie PC Care <onboarding@resend.dev>

# ─── Pipeline 2 — Google Sheets (lead log) ─────────────────────────────

# Apps Script web-app URL. Walkthrough in DEPLOY.md → Step 5.
# Looks like: https://script.google.com/macros/s/AKfycby......./exec
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional shared secret. If you set SHARED_SECRET inside the Apps Script
# (sheets-webhook.gs), set the SAME value here. If both are blank the
# webhook is open (URL-only obscurity).
SHEETS_SECRET=
